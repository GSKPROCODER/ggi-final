# Database
DATABASE_URL="postgresql://user:password@host/dbname"
# Optional, dev-only: skip TLS cert verification for self-signed Postgres. Never set in production.
# DATABASE_SSL_NO_VERIFY="true"

# Clerk Authentication
# Development instance keys start with pk_test_ / sk_test_.
# Production instance keys start with pk_live_ / sk_live_ — set those in your
# hosting provider (e.g. Vercel) for the production deployment.
# Sign-in/up routes and post-auth redirects are configured in src/app/layout.tsx,
# so no NEXT_PUBLIC_CLERK_*_URL variables are required.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."

# AI Providers (at least one required for analysis; GEMINI_API_KEY also powers the agent)
GEMINI_API_KEY="..."
GROQ_API_KEY="..."
OPENROUTER_API_KEY="..."

# Storage (optional — without it, uploads fall back to local /tmp)
BLOB_READ_WRITE_TOKEN="..."

# App — canonical production URL for SEO (robots/sitemap/metadata)
NEXT_PUBLIC_APP_URL="https://your-domain.com"
